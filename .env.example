# ---- Shared ----
LOG_LEVEL=INFO

# ---- API Gateway ----
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# JWT signing key — replace in real deployments. HS256 by default.
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
# Audience is checked on every request if set; leave blank to skip.
JWT_AUDIENCE=

# Rate limit: requests/sec per authenticated user (sub claim).
RATE_LIMIT_PER_SECOND=10
RATE_LIMIT_BURST=10

# Where the orchestrator lives. The gateway talks to it over HTTP.
ORCHESTRATOR_URL=http://orchestrator:9000
ORCHESTRATOR_TIMEOUT_SECONDS=10

# ---- Orchestrator ----
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=9000

# Sandbox pool sizing.
POOL_MIN_SIZE=2
POOL_MAX_SIZE=10

# Idle timeout before a sandbox in IN_USE state is reclaimed (seconds).
IDLE_TIMEOUT_SECONDS=600

# Health check cadence (seconds).
HEALTH_CHECK_INTERVAL_SECONDS=30

# Sandbox backend. "mock" for local dev; "firecracker" for real VM execution.
SANDBOX_BACKEND=mock

# ---- Firecracker backend (only needed when SANDBOX_BACKEND=firecracker) ----
# SANDBOX_BACKEND=firecracker
# FIRECRACKER_BINARY=/usr/local/bin/firecracker
# FIRECRACKER_SNAP_FILE=/home/ubuntu/firecracker-demo/snap.file
# FIRECRACKER_SNAP_MEM=/home/ubuntu/firecracker-demo/snap.mem
# FIRECRACKER_POOL_SIZE=0
